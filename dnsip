echo "正在批量测速日本 DNS，请稍候..."
echo "----------------------------------------"

tmp=$(mktemp)

for ip in $ips; do
  avg=$(ping -c 4 -W 1 -q "$ip" 2>/dev/null | awk -F'/' '/^rtt/ {print $5}' | awk '{print int($0+0.5)}')
  [ -z "$avg" ] && avg=9999
  echo "$avg $ip" >> "$tmp"
done

echo "测速结果（延迟 ms 从小到大）："
echo "----------------------------------------"
sort -n "$tmp" | awk '{
    if($1 < 1000) printf "%4d ms  %s\n", $1, $2
    else printf "  超时  %s\n", $2
}'

rm -f "$tmp"
